---
interface Props {
  title: string;
  description: string;
  canonicalUrl?: string;
}

const { title, description, canonicalUrl } = Astro.props;
const siteUrl = import.meta.env.SITE || "https://iroak.cl";
const canonical = canonicalUrl || new URL(Astro.url.pathname, siteUrl).href;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#110d10" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#fdf7f3" media="(prefers-color-scheme: light)" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" type="application/xml" href="/sitemap.xml" />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "Index - Directorio de paginas de iroaK",
      "url": siteUrl,
      "description": description,
      "publisher": {
        "@type": "Person",
        "name": "iroaK",
        "url": siteUrl
      }
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": siteUrl
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Index",
          "item": canonical
        }
      ]
    })} />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Saltar al contenido principal</a>
    <slot />
  </body>
</html>
